---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="Blog" description="Nyheder og tanker om akvarier fra Akvarievejledning.">

  <h1 class="text-4xl font-bold text-teal-900 mb-4">Blog</h1>
  <p class="text-lg text-stone-600 max-w-2xl mb-8">
    Her kommer indlæg om akvarier, aquascaping og livet med fisk. Vi er ikke helt klar endnu – men det er på vej.
  </p>

  <div class="bg-emerald-50 rounded-2xl p-8 mb-8">
    <p class="text-stone-600 mb-4">Mens du venter kan du læse vores guides og finde svar i FAQ.</p>
    <div class="flex gap-4">
      <a href="/guide" class="inline-block bg-teal-800 text-white px-5 py-2.5 rounded-xl hover:bg-teal-700 font-medium transition text-sm">Se guider</a>
      <a href="/faq" class="inline-block border border-teal-800 text-teal-800 px-5 py-2.5 rounded-xl hover:bg-teal-50 font-medium transition text-sm">Gå til FAQ</a>
    </div>
  </div>

</Layout>
