---
import Layout from '../../layouts/Layout.astro'
import { sanityClient } from '../../lib/sanity'

const kompletGuider = await sanityClient.fetch(`
  *[_type == "kompletGuide" && defined(slug.current)] | order(_createdAt asc) {
    titel,
    "slug": slug.current,
    beskrivelse
  }
`)

const hurtigeGuider = await sanityClient.fetch(`
  *[_type == "hurtigGuide" && defined(slug.current)] | order(_createdAt asc) {
    titel,
    "slug": slug.current,
    beskrivelse
  }
`)
---

<Layout title="Guide" description="Komplette og hurtige akvarieguides – fra opstart til pleje.">

  <!-- Hero -->
  <section class="mb-16 rounded-2xl overflow-hidden relative">
    <img src="/fisk-ved-koraller.jpg" alt="Blå og grå fisk ved koraller i akvarium" class="w-full h-64 object-cover" />
    <span class="absolute bottom-2 right-2 text-white/80 text-xs font-medium" style="writing-mode: vertical-rl; transform: rotate(180deg);">Foto: Shaun Low / Unsplash</span>
    <div class="absolute inset-0 bg-teal-900/60 flex flex-col items-center justify-center text-center px-6">
      <h1 class="text-4xl font-bold text-white mb-3">Komplette og hurtige akvarieguides</h1>
      <p class="text-lg text-teal-100 max-w-xl">Fra den første opstart til specifikke spørgsmål om planter, fisk og udstyr.</p>
    </div>
  </section>

  <!-- Complete guides -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-stone-800 mb-6">Komplette guides</h2>
    {kompletGuider.length > 0 ? (
      <div class="flex flex-col gap-4">
        {kompletGuider.map((guide: any) => (
          <a href={`/guide/${guide.slug}`} class="block bg-white shadow-sm rounded-2xl p-6 hover:shadow-md transition">
            <span class="text-xs font-semibold text-teal-700 uppercase tracking-wide">Komplet guide</span>
            <h3 class="text-xl font-bold mt-1 mb-2">{guide.titel}</h3>
            {guide.beskrivelse && <p class="text-stone-600">{guide.beskrivelse}</p>}
          </a>
        ))}
      </div>
    ) : (
      <p class="text-stone-500">Komplette guides kommer snart.</p>
    )}
  </section>

  <!-- Quick guides -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-stone-800 mb-6">Hurtige guides</h2>
    {hurtigeGuider.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {hurtigeGuider.map((guide: any) => (
          <a href={`/guide/${guide.slug}`} class="block bg-white shadow-sm rounded-2xl p-5 hover:shadow-md transition">
            <span class="text-xs font-semibold text-emerald-700 uppercase tracking-wide">Hurtig guide</span>
            <h3 class="font-bold mt-1 mb-1">{guide.titel}</h3>
            {guide.beskrivelse && <p class="text-sm text-stone-600">{guide.beskrivelse}</p>}
          </a>
        ))}
      </div>
    ) : (
      <p class="text-stone-500">Hurtige guides kommer snart.</p>
    )}
  </section>

</Layout>
