---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const { title, description = 'Gratis vejledning om akvarier – og professionel udlejning til kontorer.' } = Astro.props
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} – Akvarievejledning</title>
    <link rel="icon" type="image/jpeg" href="/akvarievejledning_favicon.jpg" />
    <slot name="head" />
  </head>
  <body class="bg-stone-50 text-stone-800 font-sans">
    <header id="site-header" class="fixed top-0 left-0 right-0 z-50 border-b border-stone-200 bg-stone-50" style="transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);">
      <div class="max-w-7xl mx-auto px-8 py-4 flex items-center justify-between" id="header-inner" style="transition: padding 0.6s cubic-bezier(0.4, 0, 0.2, 1);">
        <a href="/" class="flex items-center gap-3 hover:opacity-80 transition">
          <img src="/akvarievejledning_rund.png" alt="Akvarievejledning logo" id="header-logo" class="rounded-lg w-32 h-32" style="transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1), height 0.6s cubic-bezier(0.4, 0, 0.2, 1);" />
          <span class="text-xl font-bold text-teal-800">Akvarievejledning</span>
        </a>
        <nav class="flex gap-6 text-sm font-medium">
          <a href="/guide" class="hover:text-teal-700">Guides</a>
          <a href="/faq" class="hover:text-teal-700">FAQ</a>
          <a href="/akvarieudlejning" class="hover:text-teal-700">Akvarieudlejning</a>
        </nav>
      </div>
    </header>

    <!-- Spacer to prevent content from hiding behind fixed header -->
    <div id="header-spacer" class="w-full" style="height: 160px; transition: height 0.6s cubic-bezier(0.4, 0, 0.2, 1);"></div>

    <main class="max-w-4xl mx-auto px-4 py-12">
      <slot />
    </main>

    <footer class="border-t border-stone-200 mt-16">
      <div class="max-w-7xl mx-auto px-8 py-8 text-sm text-stone-500 flex justify-between">
        <p>© {new Date().getFullYear()} Akvarievejledning</p>
        <nav class="flex gap-4">
          <a href="/guide" class="hover:text-stone-700">Guides</a>
          <a href="/faq" class="hover:text-stone-700">FAQ</a>
          <a href="/akvarieudlejning" class="hover:text-stone-700">Akvarieudlejning</a>
          <a href="/om-adrian" class="hover:text-stone-700">Om Akvarievejledning</a>
        </nav>
      </div>
    </footer>

    <script>
      const headerInner = document.getElementById('header-inner')
      const logo = document.getElementById('header-logo') as HTMLImageElement | null
      const spacer = document.getElementById('header-spacer')

      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          if (logo) {
            logo.style.width = '40px'
            logo.style.height = '40px'
          }
          if (headerInner) headerInner.style.paddingTop = headerInner.style.paddingBottom = '8px'
          if (spacer) spacer.style.height = '56px'
        } else {
          if (logo) {
            logo.style.width = '128px'
            logo.style.height = '128px'
          }
          if (headerInner) headerInner.style.paddingTop = headerInner.style.paddingBottom = '16px'
          if (spacer) spacer.style.height = '160px'
        }
      })
    </script>
  </body>
</html>
